# ---------------------------------------------------------------------------
# EU Job Market Radar — environment configuration
# Copy this file to ".env" and fill in your values.  The .env file is ignored
# by git so your secrets never get committed.
# ---------------------------------------------------------------------------

# --- Email / SMTP settings (required to actually send the weekly report) ---
# Example for Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your.address@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password   (NOT your normal password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# --- Optional: LLM summarization -------------------------------------------
# LLM_PROVIDER can be: openai | anthropic | none
# If left as "none" (or empty), a deterministic fallback report is generated
# and no API key is required.
LLM_PROVIDER=none

# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Optional model override. Sensible defaults are used if left blank.
#   openai default:    gpt-4o-mini
#   anthropic default: claude-sonnet-4-6
LLM_MODEL=

# --- Optional: France Travail job API (France jobs collector) --------------
# Sweden and Germany job collectors work with no setup. France is optional:
# create free credentials at https://francetravail.io/ to enable it. If these
# are blank, the France collector simply skips.
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# --- Optional: Adzuna job API (multi-country jobs collector) ---------------
# Free key from https://developer.adzuna.com/ enables Netherlands, Spain,
# France, Italy, Poland and Austria vacancies. If blank, Adzuna is skipped.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
